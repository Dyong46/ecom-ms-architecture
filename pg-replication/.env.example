# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the PostgreSQL replication cluster.
#
# Copy this file to .env and change ALL passwords before use.
#   cp .env.example .env
#
# WARNING: The default values below are for LOCAL DEVELOPMENT ONLY.
# NEVER use these credentials in a staging or production environment.
# Use a secrets manager (Docker secrets, HashiCorp Vault, AWS Secrets Manager)
# for production deployments.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL superuser (postgres)
POSTGRES_PASSWORD=postgres

# Replication user used by streaming replicas
REPLICATION_PASSWORD=replicator

# Application admin user (createrole + createdb)
ADMIN_PASSWORD=admin
